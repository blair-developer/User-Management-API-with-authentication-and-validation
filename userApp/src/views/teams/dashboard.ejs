<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Team Dashboard</title>

    <link rel="stylesheet" href="/style.css">

    <style>

        body{
            margin:0;
            font-family:Arial;
            background:#f4f7fc;
        }

        .container{
            width:90%;
            margin:auto;
            padding:30px 0;
        }

        .top{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:30px;
        }

        .team-box{
            background:white;
            padding:25px;
            border-radius:15px;
            box-shadow:0 5px 15px rgba(0,0,0,0.1);
            margin-bottom:30px;
        }

        .stats{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
            gap:20px;
            margin-bottom:30px;
        }

        .card{
            background:white;
            padding:20px;
            border-radius:15px;
            box-shadow:0 5px 15px rgba(0,0,0,0.08);
        }

        .card h2{
            color:#4f46e5;
            font-size:35px;
        }

        .progress-bar{
            width:100%;
            height:20px;
            background:#ddd;
            border-radius:20px;
            overflow:hidden;
            margin-top:10px;
        }

        .progress{
            height:100%;
            background:#4f46e5;
        }

        .members{
            display:flex;
            flex-wrap:wrap;
            gap:15px;
            margin-top:15px;
        }

        .member{
            background:#4f46e5;
            color:white;
            padding:10px 15px;
            border-radius:30px;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
        }

        table th{
            background:#4f46e5;
            color:white;
            padding:15px;
        }

        table td{
            background:white;
            padding:15px;
            border-bottom:1px solid #eee;
        }

        .activity{
            background:white;
            padding:20px;
            border-radius:15px;
            margin-top:30px;
        }

        .activity-item{
            padding:15px 0;
            border-bottom:1px solid #eee;
        }

        .invite-form{
            margin-top:20px;
            display:flex;
            gap:10px;
        }

        .invite-form input{
            flex:1;
            padding:12px;
            border-radius:10px;
            border:1px solid #ccc;
        }

        .invite-form button{
            background:#4f46e5;
            color:white;
            border:none;
            padding:12px 20px;
            border-radius:10px;
            cursor:pointer;
        }

    </style>

</head>

<body>

<div class="container">

    <div class="top">

        <div>

            <h1><%= team.teamName %></h1>

            <p><%= team.description %></p>

        </div>

        <a href="/home">
            Back
        </a>

    </div>



    <!-- STATS -->

    <div class="stats">

        <div class="card">
            <h2><%= totalTasks %></h2>
            <p>Total Tasks</p>
        </div>

        <div class="card">
            <h2><%= completedTasks %></h2>
            <p>Completed</p>
        </div>

        <div class="card">
            <h2><%= pendingTasks %></h2>
            <p>Pending</p>
        </div>

    </div>



    <!-- PROGRESS -->

    <div class="team-box">

        <h2>Team Progress</h2>

        <div class="progress-bar">

            <div
                class="progress"
                progress
            ></div>

        </div>

        <p><%= progress %>% Completed</p>

    </div>



    <!-- MEMBERS -->

    <div class="team-box">

        <h2>Team Members</h2>

        <div class="members">

            <% team.members.forEach(member => { %>

                <div class="member">

                    <%= member.name %>

                </div>

            <% }) %>

        </div>



        <!-- INVITE -->

        <form
            action="/teams/invite"
            method="POST"
            class="invite-form"
        >

            <input
                type="hidden"
                name="teamId"
                value="<%= team._id %>"
            >

            <input
                type="text"
                name="username"
                placeholder="Enter username"
                required
            >

            <button type="submit">

                Invite

            </button>

        </form>

    </div>



    <!-- TASKS -->

    <div class="team-box">

        <h2>Team Tasks</h2>

        <table>

            <thead>

                <tr>

                    <th>Title</th>

                    <th>Status</th>

                    <th>Assigned To</th>

                    <th>Priority</th>

                </tr>

            </thead>

            <tbody>

                <% tasks.forEach(task => { %>

                    <tr>

                        <td><%= task.title %></td>

                        <td><%= task.status %></td>

                        <td>
                            <%= task.assignedTo ? task.assignedTo.name : "Unassigned" %>
                        </td>

                        <td><%= task.priority %></td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    </div>



    <!-- ACTIVITIES -->

    <div class="activity">

        <h2>Recent Activities</h2>

        <% activities.forEach(activity => { %>

            <div class="activity-item">

                <p><%= activity.action %></p>

            </div>

        <% }) %>

    </div>

</div>

</body>

</html>