<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>TaskFlow Dashboard</title>

    <link rel="stylesheet" href="/style.css">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {

            font-family: Arial, Helvetica, sans-serif;

            background: #f5f7fb;
        }

        .dashboard {

            display: flex;

            min-height: 100vh;
        }

        /* SIDEBAR */

        .sidebar {

            width: 250px;

            background: #111827;

            color: white;

            padding: 30px 20px;
        }

        .logo {

            margin-bottom: 40px;

            font-size: 28px;

            text-align: center;

            color: #60a5fa;
        }

        .sidebar nav {

            display: flex;

            flex-direction: column;

            gap: 15px;
        }

        .sidebar nav a {

            color: white;

            text-decoration: none;

            padding: 12px;

            border-radius: 8px;

            transition: 0.3s;
        }

        .sidebar nav a:hover,
        .sidebar nav .active {

            background: #2563eb;
        }

        .logout-btn {

            margin-top: 20px;

            background: #dc2626;
        }

        /* MAIN */

        .main-content {

            flex: 1;

            padding: 30px;
        }

        /* TOPBAR */

        .topbar {

            display: flex;

            justify-content: space-between;

            align-items: center;

            margin-bottom: 30px;
        }

        .welcome-box {

            display: flex;

            align-items: center;

            gap: 15px;
        }

        .avatar {

            width: 70px;

            height: 70px;

            border-radius: 50%;

            object-fit: cover;

            border: 3px solid #2563eb;
        }

        .welcome-text {

            color: #666;

            margin-top: 5px;
        }

        /* STATS */

        .stats {

            display: flex;

            gap: 20px;
        }

        .card {

            background: white;

            padding: 20px;

            border-radius: 12px;

            min-width: 140px;

            box-shadow: 0 5px 15px rgba(0,0,0,0.05);

            text-align: center;
        }

        .card h3 {

            font-size: 28px;

            color: #2563eb;
        }

        /* TASK FORM */

        .task-form-section {

            background: white;

            padding: 20px;

            border-radius: 12px;

            margin-bottom: 25px;

            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .task-form {

            display: flex;

            gap: 15px;

            flex-wrap: wrap;
        }

        .task-form input,
        .task-form select {

            flex: 1;

            padding: 12px;

            border: 1px solid #ccc;

            border-radius: 8px;
        }

        .task-form button {

            padding: 12px 20px;

            border: none;

            border-radius: 8px;

            background: #2563eb;

            color: white;

            cursor: pointer;

            transition: 0.3s;
        }

        .task-form button:hover {

            background: #1d4ed8;
        }

        /* FILTERS */

        .filter-bar {

            display: flex;

            gap: 15px;

            margin-bottom: 25px;
        }

        .filter-bar input,
        .filter-bar select {

            padding: 10px;

            border-radius: 8px;

            border: 1px solid #ccc;
        }

        .filter-bar button {

            padding: 10px 20px;

            background: #111827;

            color: white;

            border: none;

            border-radius: 8px;

            cursor: pointer;
        }

        /* TASK GRID */

        .task-grid {

            display: grid;

            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));

            gap: 20px;
        }

        .task-card {

            background: white;

            padding: 20px;

            border-radius: 12px;

            box-shadow: 0 5px 15px rgba(0,0,0,0.05);

            transition: 0.3s;
        }

        .task-card:hover {

            transform: translateY(-5px);
        }

        .task-header {

            display: flex;

            justify-content: space-between;

            align-items: center;

            margin-bottom: 10px;
        }

        .task-desc {

            color: #555;

            margin-bottom: 15px;
        }

        .category {

            background: #dbeafe;

            color: #1d4ed8;

            padding: 5px 10px;

            border-radius: 20px;

            font-size: 12px;
        }

        .status-completed {

            background: #22c55e;

            color: white;

            padding: 5px 10px;

            border-radius: 20px;

            font-size: 12px;
        }

        .status-pending {

            background: #f59e0b;

            color: white;

            padding: 5px 10px;

            border-radius: 20px;

            font-size: 12px;
        }

        .task-actions {

            display: flex;

            gap: 10px;

            flex-wrap: wrap;
        }

        .task-actions a {

            text-decoration: none;

            padding: 8px 12px;

            border-radius: 6px;

            color: white;

            font-size: 14px;
        }

        .complete-btn {

            background: #22c55e;
        }

        .edit-btn {

            background: #2563eb;
        }

        .delete-btn {

            background: #dc2626;
        }

    </style>
</head>

<body>

<div class="dashboard">

    <!-- SIDEBAR -->

    <aside class="sidebar">

        <h2 class="logo">TaskFlow</h2>

        <nav>

            <a href="/home" class="active">
                Dashboard
            </a>

            <a href="/profile">
                Profile
            </a>

            <a href="/home?status=Completed">
                Completed
            </a>

            <a href="/logout" class="logout-btn">
                Logout
            </a>

        </nav>

    </aside>

    <!-- MAIN CONTENT -->

    <main class="main-content">

        <!-- TOPBAR -->

        <div class="topbar">

            <div class="welcome-box">

                <img
                    src="<%= profileImage %>"
                    class="avatar"
                >

                <div>

                    <h1>
                        Welcome, <%= fullname %> 👋
                    </h1>

                    <p class="welcome-text">
                        Manage your productivity today
                    </p>

                </div>

            </div>

            <!-- STATS -->

            <div class="stats">

                <div class="card">

                    <h3><%= totalTasks %></h3>

                    <p>Total Tasks</p>

                </div>

                <div class="card">

                    <h3><%= completedTasks %></h3>

                    <p>Completed</p>

                </div>

                <div class="card">

                    <h3><%= pendingTasks %></h3>

                    <p>Pending</p>

                </div>

            </div>

        </div>

        <!-- ADD TASK -->

        <section class="task-form-section">

            <form action="/add-task" method="POST" class="task-form">

                <input
                    type="text"
                    name="title"
                    placeholder="Task Title"
                    required
                >

                <input
                    type="text"
                    name="description"
                    placeholder="Task Description"
                >

                <select name="category">

                    <option value="General">General</option>

                    <option value="Work">Work</option>

                    <option value="School">School</option>

                    <option value="Personal">Personal</option>

                    <option value="Urgent">Urgent</option>

                </select>

                <button type="submit">
                    + Add Task
                </button>

            </form>

        </section>

        <!-- FILTERS -->

        <form method="GET" action="/home" class="filter-bar">

            <input
                type="text"
                name="search"
                placeholder="Search tasks"
            >

            <select name="status">

                <option value="">All Status</option>

                <option value="Pending">Pending</option>

                <option value="Completed">Completed</option>

            </select>

            <select name="category">

                <option value="">All Categories</option>

                <option value="Work">Work</option>

                <option value="School">School</option>

                <option value="Personal">Personal</option>

                <option value="Urgent">Urgent</option>

            </select>

            <button type="submit">
                Filter
            </button>

        </form>

        <!-- TASK GRID -->

        <section class="task-grid">

            <% if (tasks.length === 0) { %>

                <p>No tasks yet 👀</p>

            <% } %>

            <% tasks.forEach(task => { %>

                <div class="task-card">

                    <div class="task-header">

                        <h3><%= task.title %></h3>

                        <span class="
                            <%= task.status === 'Completed'
                            ? 'status-completed'
                            : 'status-pending' %>
                        ">
                            <%= task.status %>
                        </span>

                    </div>

                    <p class="task-desc">

                        <%= task.description %>

                    </p>

                    <span class="category">

                        <%= task.category %>

                    </span>

                    <br><br>

                    <div class="task-actions">

                        <% if (task.status !== 'Completed') { %>

                            <a
                                href="/complete-task/<%= task._id %>"
                                class="complete-btn"
                            >
                                Complete
                            </a>

                        <% } %>

                        <a
                            href="/edit-task/<%= task._id %>"
                            class="edit-btn"
                        >
                            Edit
                        </a>

                        <a
                            href="/delete-task/<%= task._id %>"
                            class="delete-btn"
                            onclick="return confirm('Delete this task?')"
                        >
                            Delete
                        </a>

                    </div>

                </div>

            <% }) %>

        </section>

    </main>

</div>

</body>
</html>