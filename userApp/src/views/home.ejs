<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Dashboard</title>

    <link rel="stylesheet" href="/style.css">
    <style>
        .welcome-text {

    margin-top: 5px;

    color: #666;

    font-size: 16px;
}

.status-completed {

    background: #22c55e;

    color: white;

    padding: 5px 10px;

    border-radius: 20px;

    font-size: 12px;
}

.status-pending {

    background: #f59e0b;

    color: white;

    padding: 5px 10px;

    border-radius: 20px;

    font-size: 12px;
}

.complete-btn {

    background: #22c55e;

    color: white;

    padding: 8px 12px;

    border-radius: 6px;

    text-decoration: none;

    font-size: 14px;
}

.complete-btn:hover {

    opacity: 0.9;
}
    </style>
</head>

<body>

<div class="dashboard">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <h2 class="logo">TaskFlow</h2>

        <nav>

            <a href="#" class="active">Dashboard</a>

            <a href="#">Tasks</a>

            <a href="#">Completed</a>

            <a href="/logout" class="logout-btn">
                Logout
            </a>

        </nav>

    </aside>

    <!-- MAIN CONTENT -->
    <main class="main-content">

        <!-- TOP BAR -->
        <div class="topbar">

            <div>
                <h1>Dashboard</h1>

                <p class="welcome-text">
                    Welcome,
                    <strong><%= username %></strong> 👋
                </p>
            </div>

            <div class="stats">

                <div class="card">

                    <h3><%= totalTasks %></h3>

                    <p>Total Tasks</p>

                </div>

                <div class="card">

                    <h3><%= completedTasks %></h3>

                    <p>Completed</p>

                </div>

                <div class="card">

                    <h3><%= pendingTasks %></h3>

                    <p>Pending</p>

                </div>

            </div>

        </div>

        <!-- ADD TASK -->
        <section class="task-form-section">

            <form action="/add-task" method="POST" class="task-form">

                <input
                    type="text"
                    name="title"
                    placeholder="Task Title"
                    required
                >

                <input
                    type="text"
                    name="description"
                    placeholder="Task Description"
                >

                <button type="submit">
                    + Add Task
                </button>

            </form>

        </section>

        <!-- TASK GRID -->
        <section class="task-grid">

            <% if (tasks.length === 0) { %>

                <p>No tasks yet 👀</p>

            <% } %>

            <% tasks.forEach(task => { %>

                <div class="task-card">

                    <div class="task-header">

                        <h3><%= task.title %></h3>

                        <!-- STATUS -->
                        <span class="
                            <%= task.status === 'Completed'
                            ? 'status-completed'
                            : 'status-pending' %>
                        ">
                            <%= task.status %>
                        </span>

                    </div>

                    <p class="task-desc">
                        <%= task.description %>
                    </p>

                    <div class="task-actions">

                        <!-- COMPLETE BUTTON -->
                        <% if (task.status !== "Completed") { %>

                            <a
                                href="/complete-task/<%= task._id %>"
                                class="complete-btn"
                            >
                                Complete
                            </a>

                        <% } %>

                        <a
                            href="/edit-task/<%= task._id %>"
                            class="edit-btn"
                        >
                            Edit
                        </a>

                        <a
                            href="/delete-task/<%= task._id %>"
                            class="delete-btn"
                            onclick="return confirm('Delete this task?')"
                        >
                            Delete
                        </a>

                    </div>

                </div>

            <% }) %>

        </section>

    </main>

</div>

</body>
</html>