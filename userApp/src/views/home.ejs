<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>TaskFlow Dashboard</title>

    <link rel="stylesheet" href="/css/home.css">

</head>

<body>

<div class="dashboard">

    <!-- SIDEBAR -->

    <aside class="sidebar">

        <h2 class="logo">TaskFlow</h2>

        <nav>

            <a href="/home" class="active">
                Dashboard
            </a>

            <a href="/profile">
                Profile
            </a>

            <a href="/home?status=Completed">
                Completed
            </a>

            <a href="/logout" class="logout-btn">
                Logout
            </a>

        </nav>

    </aside>

    <!-- MAIN CONTENT -->

    <main class="main-content">

        <!-- TOPBAR -->

        <div class="topbar">

            <div class="welcome-box">

                <img
                    src="<%= profileImage %>"
                    class="avatar"
                >

                <div>

                    <h1>
                        Welcome, <%= fullname %> 👋
                    </h1>

                    <p class="welcome-text">
                        Manage your productivity today
                    </p>

                </div>

            </div>

            <!-- STATS -->

            <div class="stats">

                <div class="card">

                    <h3><%= totalTasks %></h3>

                    <p>Total Tasks</p>

                </div>

                <div class="card">

                    <h3><%= completedTasks %></h3>

                    <p>Completed</p>

                </div>

                <div class="card">

                    <h3><%= pendingTasks %></h3>

                    <p>Pending</p>

                </div>

            </div>

        </div>

        <!-- ADD TASK -->

        <section class="task-form-section">

            <form action="/add-task" method="POST" class="task-form">

                <input
                    type="text"
                    name="title"
                    placeholder="Task Title"
                    required
                >

                <input
                    type="text"
                    name="description"
                    placeholder="Task Description"
                >

                <select name="category">

                    <option value="General">General</option>

                    <option value="Work">Work</option>

                    <option value="School">School</option>

                    <option value="Personal">Personal</option>

                    <option value="Urgent">Urgent</option>

                </select>

                <button type="submit">
                    + Add Task
                </button>

            </form>

        </section>

        <!-- CREATE TEAM -->

<section class="task-form-section">

    <h2 class="section-title">
        Create Team Workspace
    </h2>

    <form
        action="/teams/create"
        method="POST"
        class="task-form"
    >

        <input
            type="text"
            name="teamName"
            placeholder="Team Name"
            required
        >

        <input
            type="text"
            name="description"
            placeholder="Team Description"
        >

        <button type="submit">
            + Create Team
        </button>

           </form>

         </section>


        <!-- FILTERS -->

        <form method="GET" action="/home" class="filter-bar">

            <input
                type="text"
                name="search"
                placeholder="Search tasks"
            >

            <select name="status">

                <option value="">All Status</option>

                <option value="Pending">Pending</option>

                <option value="Completed">Completed</option>

            </select>

            <select name="category">

                <option value="">All Categories</option>

                <option value="Work">Work</option>

                <option value="School">School</option>

                <option value="Personal">Personal</option>

                <option value="Urgent">Urgent</option>

            </select>

            <button type="submit">
                Filter
            </button>

        </form>

        <!-- TASK GRID -->

        <section class="task-grid">

            <% if (tasks.length === 0) { %>

                <p>No tasks yet 👀</p>

            <% } %>

            <% tasks.forEach(task => { %>

                <div class="task-card">

                    <div class="task-header">

                        <h3><%= task.title %></h3>

                        <span class="
                            <%= task.status === 'Completed'
                            ? 'status-completed'
                            : 'status-pending' %>
                        ">
                            <%= task.status %>
                        </span>

                    </div>

                    <p class="task-desc">

                        <%= task.description %>

                    </p>

                    <span class="category">

                        <%= task.category %>

                    </span>

                    <br><br>

                    <div class="task-actions">

                        <% if (task.status !== 'Completed') { %>

                            <a
                                href="/complete-task/<%= task._id %>"
                                class="complete-btn"
                            >
                                Complete
                            </a>

                        <% } %>

                        <a
                            href="/edit-task/<%= task._id %>"
                            class="edit-btn"
                        >
                            Edit
                        </a>

                        <a
                            href="/delete-task/<%= task._id %>"
                            class="delete-btn"
                            onclick="return confirm('Delete this task?')"
                        >
                            Delete
                        </a>

                    </div>

                </div>

            <% }) %>

        </section>

        <!-- MY TEAMS -->

<section class="teams-section">

    <div class="section-header">

        <h2>My Teams</h2>

    </div>

    <div class="teams-grid">

        <% if (teams.length === 0) { %>

            <p>No teams yet 🚀</p>

        <% } %>

        <% teams.forEach(team => { %>

            <div class="team-card">

                <h3><%= team.teamName %></h3>

                <p>
                    <%= team.description %>
                </p>

                <div class="team-meta">

                    <span>
                        👥 <%= team.members.length %> Members
                    </span>

                </div>

                <a
                    href="/teams/<%= team._id %>"
                    class="view-team-btn"
                >
                    Open Workspace
                </a>

            </div>

        <% }) %>

    </div>

</section>

    </main>

</div>

</body>
</html>